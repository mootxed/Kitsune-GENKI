{
  "name": "kitsune-genki",
  "version": "1.0.0",
  "type": "module",
  "description": "PWA приложение для изучения японского языка",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "keywords": [
    "japanese",
    "learning",
    "pwa",
    "genki"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.1.0",
    "prettier": "^3.9.5",
    "terser": "^5.49.0",
    "vite": "^5.4.11",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "caveman-shrink": "^0.1.0",
    "headroom-ai": "^0.22.4",
    "rtk": "^4.2.0"
  },
  "lint-staged": {
    "*.js": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
